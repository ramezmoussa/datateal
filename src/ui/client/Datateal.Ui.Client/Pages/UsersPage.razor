@page "/users"
@attribute [Authorize(Policy = AuthPolicy.Admin)]

@using Datateal.Ui.Shared.Catalogs
@using Datateal.Ui.Shared.Users
@using Datateal.Ui.Shared.Workspaces
@inject IUserService UserService
@inject ICatalogService CatalogService
@inject IWorkspaceManagementService WorkspaceService

<PageTitle>Users — Datateal</PageTitle>

<Space>
    <SpaceItem>
        <Icon Height="24px" Width="24px" Type="@IconType.Outline.Team" />
    </SpaceItem>
    <SpaceItem>
        <h2>Users</h2>
    </SpaceItem>
</Space>

@if (!string.IsNullOrEmpty(_error))
{
    <Alert Type="@AlertType.Error" Message="@_error" Closable OnClose="() => _error = null"
           Style="margin-bottom: 16px;" />
}

<Flex Justify="FlexJustify.FlexEnd" Style="margin-bottom: 12px;">
    <Button Type="@ButtonType.Primary" OnClick="StartCreate">
        <Icon Type="@IconType.Outline.Plus" /> New user
    </Button>
</Flex>

<Spin Spinning="_loading">
    <Table TItem="AppUserDto" DataSource="_users" Size="@TableSize.Small" PageSize="int.MaxValue" PaginationPosition="none">
        <PropertyColumn Property="u => u.Email" Title="Email" Sortable>
            <span style="font-family: monospace;">@context.Email</span>
        </PropertyColumn>
        <PropertyColumn Property="u => u.DisplayName" Title="Display Name" Sortable />
        <PropertyColumn Property="u => u.IsEnabled" Title="Status" Sortable>
            @if (context.IsEnabled)
            {
                <Tag Color="@("green")">Enabled</Tag>
            }
            else
            {
                <Tag Color="@("red")">Disabled</Tag>
            }
        </PropertyColumn>
        <PropertyColumn Property="u => u.Roles" Title="Roles">
            @foreach (var role in context.Roles)
            {
                <Tag Color="@("blue")" Style="margin-bottom: 2px;">@role</Tag>
            }
        </PropertyColumn>
        <PropertyColumn Property="u => u.HasAllCatalogAccess" Title="Catalog Access">
            @if (context.Roles.Contains(DatatealRole.Admin) || context.Roles.Contains(DatatealRole.CatalogContributor))
            {
                <span>All (implicit)</span>
            }
            else if (context.HasAllCatalogAccess)
            {
                <span>All</span>
            }
            else if (context.CatalogAccessList.Count > 0)
            {
                <span>@context.CatalogAccessList.Count catalog(s)</span>
            }
            else
            {
                <span style="color: #8c8c8c;">None</span>
            }
        </PropertyColumn>
        <PropertyColumn Property="u => u.CreatedAt" Title="Created" Sortable>
            @context.CreatedAt.ToString("yyyy-MM-dd")
        </PropertyColumn>
        <ActionColumn Title="Actions">
            <Space>
                <SpaceItem>
                    <Tooltip Title="Edit">
                        <Button Size="@ButtonSize.Small" OnClick="() => StartEdit(context)">
                            <Icon Type="@IconType.Outline.Edit" />
                        </Button>
                    </Tooltip>
                </SpaceItem>
                <SpaceItem>
                    <Tooltip Title="Delete">
                        <Popconfirm Title="@($"Delete user '{context.Email}'?")"
                                    OnConfirm="() => DeleteAsync(context)">
                            <Button Danger Size="@ButtonSize.Small">
                                <Icon Type="@IconType.Outline.Delete" />
                            </Button>
                        </Popconfirm>
                    </Tooltip>
                </SpaceItem>
            </Space>
        </ActionColumn>
    </Table>
</Spin>

<Drawer Closable="true" @bind-Visible="_showModal" Placement="DrawerPlacement.Right"
        Width="520" Title="@(_editTarget is null ? "New user" : "Edit user")"
        OnClose="() => _showModal = false"
        BodyStyle="display: flex; flex-direction: column; padding: 0; overflow: hidden;">
    <div style="flex: 1; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 16px;">
        <Form Model="@_form" Layout="FormLayout.Vertical">
            @if (_editTarget is null)
            {
                <FormItem Label="Email">
                    <Input @bind-Value="context.Email" Placeholder="user@example.com"
                           BindOnInput
                           Class="@(EmailDisplayError is not null ? "ant-input-status-error" : "")" />
                    @if (EmailDisplayError is not null)
                    {
                        <div class="ant-form-item-explain-error">@EmailDisplayError</div>
                    }
                </FormItem>
            }
            else
            {
                <FormItem Label="Email">
                    <Input Value="@_editTarget.Email" Disabled />
                </FormItem>
            }

            <FormItem Label="Display Name">
                <Input @bind-Value="context.DisplayName" Placeholder="John Doe"
                       BindOnInput
                       Class="@(DisplayNameDisplayError is not null ? "ant-input-status-error" : "")" />
                @if (DisplayNameDisplayError is not null)
                {
                    <div class="ant-form-item-explain-error">@DisplayNameDisplayError</div>
                }
            </FormItem>

            @if (_editTarget is not null)
            {
                <FormItem Label="Enabled">
                    <Switch @bind-Checked="context.IsEnabled" />
                </FormItem>
            }

            <FormItem Label="Roles">
                <div style="color: #8c8c8c; font-size: 12px; margin-bottom: 8px;">
                    Tenant-wide roles that apply across the whole instance. Workspace-specific
                    roles (e.g. WorkspaceAdmin, contributors, operators) are granted per workspace
                    from that workspace's <b>Members</b> list on the Workspaces page.
                </div>
                <CheckboxGroup @bind-Value="_selectedRoles" TValue="string" Style="width:100%">
                    <GridRow Gutter="(0, 8)">
                        @foreach (var role in DatatealRole.TenantGlobal)
                        {
                            <GridCol Span="12">
                                <Checkbox Label="@role">
                                    @role
                                    <Popover ContentTemplate="@RoleInfoContent(role)" Title="@role">
                                        <Icon Type="info-circle"
                                              Style="margin-left: 4px; color: #8c8c8c; cursor: default; font-size: 12px; vertical-align: middle;" />
                                    </Popover>
                                </Checkbox>
                            </GridCol>
                        }
                    </GridRow>
                </CheckboxGroup>
            </FormItem>

            <FormItem Label="Catalog Access">
                <Checkbox Checked="_form.HasAllCatalogAccess"
                          CheckedChanged="v => _form.HasAllCatalogAccess = v">
                    Access to all catalogs (present and future)
                </Checkbox>
            </FormItem>

            @if (!_form.HasAllCatalogAccess && !_form.SelectedRoles.Contains(DatatealRole.Admin)
                && !_form.SelectedRoles.Contains(DatatealRole.CatalogContributor))
            {
                <FormItem Label="Specific Catalogs">
                    <Select TItem="CatalogDto"
                            TItemValue="Guid"
                            DataSource="_catalogs"
                            Mode="@SelectMode.Multiple"
                            @bind-Values="_selectedCatalogIds"
                            ValueName="@nameof(CatalogDto.Id)"
                            LabelName="@nameof(CatalogDto.Name)"
                            Placeholder="Select catalogs..."
                            AllowClear />
                </FormItem>
            }

            @if (_workspaces.Count > 0)
            {
                <FormItem Label="Workspace access">
                    <div style="color: #8c8c8c; font-size: 12px; margin-bottom: 8px;">
                        Grant per-workspace roles directly here, or manage them later from each
                        workspace's <b>Members</b> list on the Workspaces page. Leave a workspace
                        empty to grant no access.
                    </div>
                    <Table TItem="WorkspaceDto" DataSource="_workspaces" Size="@TableSize.Small"
                           Context="ws" PageSize="int.MaxValue" PaginationPosition="none">
                        <PropertyColumn Property="w => w.Name" Title="Workspace" />
                        <ActionColumn Title="Roles">
                            <Select Mode="SelectMode.Multiple"
                                    TItemValue="string" TItem="string"
                                    Values="@WorkspaceRolesFor(ws.Id)"
                                    ValuesChanged="@((IEnumerable<string> v) => SetWorkspaceRoles(ws.Id, v))"
                                    Placeholder="No access"
                                    Style="width: 100%; min-width: 220px;"
                                    AllowClear>
                                <SelectOptions>
                                    @foreach (var role in DatatealRole.PerWorkspace)
                                    {
                                        <SelectOption TItemValue="string" TItem="string" Value="@role" Label="@role" />
                                    }
                                </SelectOptions>
                            </Select>
                        </ActionColumn>
                    </Table>
                </FormItem>
            }

            @if (_saveError is not null)
            {
                <Alert Type="@AlertType.Error" Message="@_saveError" ShowIcon="true" />
            }
        </Form>
    </div>
    <div class="drawer-footer">
        <Button OnClick="() => _showModal = false">Cancel</Button>
        <Button Type="@ButtonType.Primary" OnClick="ConfirmSave"
                Disabled="@(!IsFormValid() || _saving)" Loading="_saving">Save</Button>
    </div>
</Drawer>

@code {
    private IReadOnlyList<AppUserDto> _users = [];
    private IReadOnlyList<CatalogDto> _catalogs = [];
    private IReadOnlyList<WorkspaceDto> _workspaces = [];
    private Dictionary<Guid, IReadOnlyList<WorkspaceMemberDto>> _membershipsByWorkspace = [];
    private bool _loading = true;
    private string? _error;

    private bool _showModal;
    private AppUserDto? _editTarget;
    private UserFormModel _form = new();
    private bool _saving;
    private string? _saveError;
    private bool _submitAttempted;

    // Checkbox group binding
    private string[] _selectedRoles = [];
    private IEnumerable<Guid> _selectedCatalogIds = [];

    // Per-workspace roles selected in the modal, keyed by workspace id.
    private Dictionary<Guid, string[]> _workspaceRoles = [];

    private IEnumerable<string> WorkspaceRolesFor(Guid workspaceId) =>
        _workspaceRoles.TryGetValue(workspaceId, out var roles) ? roles : [];

    private void SetWorkspaceRoles(Guid workspaceId, IEnumerable<string>? roles) =>
        _workspaceRoles[workspaceId] = roles?.ToArray() ?? [];

    private RenderFragment RoleInfoContent(string role) =>
        @<span style="max-width: 260px; display: block;">@RoleCatalog.Describe(role)</span>;

    private string? EmailDisplayError =>
        (_submitAttempted || !string.IsNullOrEmpty(_form.Email)) ? GetEmailError() : null;

    private string? DisplayNameDisplayError =>
        (_submitAttempted || !string.IsNullOrEmpty(_form.DisplayName)) ? GetDisplayNameError() : null;

    private string? GetEmailError()
    {
        if (string.IsNullOrWhiteSpace(_form.Email)) return "Email is required.";
        if (!_form.Email.Contains('@')) return "Invalid email format.";
        if (_users.Any(u => u.Email.Equals(_form.Email.Trim(), StringComparison.OrdinalIgnoreCase)
                            && u != _editTarget))
            return "A user with this email already exists.";
        return null;
    }

    private string? GetDisplayNameError() =>
        string.IsNullOrWhiteSpace(_form.DisplayName) ? "Display name is required." : null;

    private bool IsFormValid()
    {
        if (_editTarget is null && GetEmailError() is not null) return false;
        if (GetDisplayNameError() is not null) return false;
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadUsersAsync(), LoadCatalogsAsync(), LoadWorkspacesAsync());
    }

    private async Task LoadUsersAsync()
    {
        _loading = true;
        try { _users = await UserService.GetUsersAsync(); }
        catch (Exception ex) { _error = $"Failed to load users: {ex.Message}"; }
        finally { _loading = false; }
    }

    private async Task LoadCatalogsAsync()
    {
        try { _catalogs = await CatalogService.GetAllCatalogsAsync(); }
        catch { /* non-fatal — catalog picker just won't have data */ }
    }

    private async Task LoadWorkspacesAsync()
    {
        try
        {
            _workspaces = await WorkspaceService.GetAccessibleAsync();
            await LoadMembershipsAsync();
        }
        catch { /* non-fatal — workspace access section just won't have data */ }
    }

    private async Task LoadMembershipsAsync()
    {
        var map = new Dictionary<Guid, IReadOnlyList<WorkspaceMemberDto>>();
        foreach (var ws in _workspaces)
        {
            try { map[ws.Id] = await WorkspaceService.GetMembersAsync(ws.Id); }
            catch { map[ws.Id] = []; }
        }
        _membershipsByWorkspace = map;
    }

    private Dictionary<Guid, string[]> BuildWorkspaceRoles(Guid? userId)
    {
        var map = new Dictionary<Guid, string[]>();
        foreach (var ws in _workspaces)
        {
            string[] roles = [];
            if (userId is not null
                && _membershipsByWorkspace.TryGetValue(ws.Id, out var members))
            {
                var membership = members.FirstOrDefault(m => m.UserId == userId);
                if (membership is not null) roles = membership.Roles.ToArray();
            }
            map[ws.Id] = roles;
        }
        return map;
    }

    private void StartCreate()
    {
        _editTarget = null;
        _form = new UserFormModel();
        _selectedRoles = [];
        _selectedCatalogIds = [];
        _workspaceRoles = BuildWorkspaceRoles(null);
        _submitAttempted = false;
        _saveError = null;
        _showModal = true;
    }

    private void StartEdit(AppUserDto user)
    {
        _editTarget = user;
        _form = new UserFormModel
        {
            DisplayName = user.DisplayName,
            IsEnabled = user.IsEnabled,
            HasAllCatalogAccess = user.HasAllCatalogAccess,
            SelectedRoles = user.Roles.ToList(),
        };
        _selectedRoles = user.Roles.ToArray();
        _selectedCatalogIds = user.CatalogAccessList.Select(a => a.CatalogId);
        _workspaceRoles = BuildWorkspaceRoles(user.Id);
        _submitAttempted = false;
        _saveError = null;
        _showModal = true;
    }

    private async Task ConfirmSave()
    {
        _submitAttempted = true;
        if (!IsFormValid()) return;

        _saving = true;
        _saveError = null;
        try
        {
            var roles = _selectedRoles.ToList();
            var catalogIds = _form.HasAllCatalogAccess
                || roles.Contains(DatatealRole.Admin)
                || roles.Contains(DatatealRole.CatalogContributor)
                    ? []
                    : _selectedCatalogIds.ToList();

            if (_editTarget is null)
            {
                var created = await UserService.CreateUserAsync(new CreateUserRequest(
                    _form.Email.Trim(),
                    _form.DisplayName.Trim(),
                    roles,
                    _form.HasAllCatalogAccess,
                    catalogIds));
                await SyncWorkspaceMembershipsAsync(created.Id);
            }
            else
            {
                await UserService.UpdateUserAsync(_editTarget.Id, new UpdateUserRequest(
                    _form.DisplayName.Trim(),
                    _form.IsEnabled,
                    roles,
                    _form.HasAllCatalogAccess,
                    catalogIds));
                await SyncWorkspaceMembershipsAsync(_editTarget.Id);
            }
            _showModal = false;
            await Task.WhenAll(LoadUsersAsync(), LoadMembershipsAsync());
        }
        catch (Exception ex) { _saveError = $"Failed to save user: {ex.Message}"; }
        finally { _saving = false; }
    }

    private async Task SyncWorkspaceMembershipsAsync(Guid userId)
    {
        foreach (var ws in _workspaces)
        {
            var desired = _workspaceRoles.TryGetValue(ws.Id, out var r) ? r : [];
            var original = OriginalWorkspaceRoles(userId, ws.Id);
            if (RolesEqual(desired, original)) continue;

            if (desired.Length == 0)
                await WorkspaceService.RemoveMemberAsync(ws.Id, userId);
            else
                await WorkspaceService.SetMemberAsync(ws.Id,
                    new SetWorkspaceMemberRequest(userId, desired.ToList()));
        }
    }

    private string[] OriginalWorkspaceRoles(Guid userId, Guid workspaceId)
    {
        if (_membershipsByWorkspace.TryGetValue(workspaceId, out var members))
        {
            var membership = members.FirstOrDefault(m => m.UserId == userId);
            if (membership is not null) return membership.Roles.ToArray();
        }
        return [];
    }

    private static bool RolesEqual(IReadOnlyCollection<string> a, IReadOnlyCollection<string> b) =>
        a.Count == b.Count && new HashSet<string>(a).SetEquals(b);

    private async Task DeleteAsync(AppUserDto user)
    {
        try
        {
            await UserService.DeleteUserAsync(user.Id);
            await LoadUsersAsync();
        }
        catch (Exception ex) { _error = $"Failed to delete user: {ex.Message}"; }
    }

    private class UserFormModel
    {
        public string Email { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public bool IsEnabled { get; set; } = true;
        public bool HasAllCatalogAccess { get; set; }
        public List<string> SelectedRoles { get; set; } = [];
    }
}
