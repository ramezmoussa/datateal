@using Datateal.Ui.Shared.Catalogs
@using Datateal.Ui.Client.Components
@using Datateal.Ui.Client.Services
@inject ICatalogService CatalogService

@if (Selection is null)
{
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center;
                height: 100%; color: rgba(0,0,0,0.35); text-align: center; padding: 32px;">
        <Icon Type="@IconType.Outline.Database" Style="font-size: 48px; margin-bottom: 16px; opacity: 0.3;" />
        <div style="font-size: 0.9rem;">Select a catalog, table, or view to see its details.</div>
    </div>
}
else if (Selection.SelectedCatalog is { } catalog)
{
    <div style="padding: 20px; overflow-y: auto; height: 100%;">
        @* Header *@
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">
            <Icon Type="@IconType.Outline.Database" Style="font-size: 1.1rem;" />
            <span style="font-family: monospace; font-size: 1.1rem; font-weight: 600;">@catalog.Name</span>
            @if (catalog is ManagedCatalogDto)
            {
                <Tag Color="@("blue")">Managed</Tag>
            }
            else
            {
                <Tag Color="@("orange")">Unmanaged</Tag>
            }
        </div>

        @* Connection details *@
        <div style="margin-bottom: 24px;">
            <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
                        letter-spacing: 0.05em; opacity: 0.5; margin-bottom: 8px;">Connection</div>
            <div style="display: grid; grid-template-columns: 110px 1fr; row-gap: 4px; font-size: 0.875rem;">
                <span style="opacity: 0.55;">Host</span>
                <span style="font-family: monospace;">@catalog.CatalogHost</span>
                <span style="opacity: 0.55;">Port</span>
                <span style="font-family: monospace;">@catalog.CatalogPort</span>
                <span style="opacity: 0.55;">Database</span>
                <span style="font-family: monospace;">@catalog.CatalogDatabase</span>
                <span style="opacity: 0.55;">User</span>
                <span style="font-family: monospace;">@catalog.CatalogUser</span>
                @if (!string.IsNullOrEmpty(catalog.DataPath))
                {
                    <span style="opacity: 0.55;">Data path</span>
                    <span style="font-family: monospace; word-break: break-all;">@catalog.DataPath</span>
                }
                <span style="opacity: 0.55;">Created</span>
                <span>@catalog.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                <span style="opacity: 0.55;">Updated</span>
                <span>@catalog.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</span>
            </div>
        </div>

        @* DuckLake metadata *@
        <div>
            <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
                        letter-spacing: 0.05em; opacity: 0.5; margin-bottom: 6px;">DuckLake Metadata</div>

            @if (_catalogInfoLoading)
            {
                <Flex Justify="@("center")" Style="padding: 24px;">
                    <Spin />
                </Flex>
            }
            else if (_catalogInfoError is not null)
            {
                <Alert Type="@AlertType.Error" Message="@_catalogInfoError" />
            }
            else if (_catalogInfo is null || _catalogInfo.Metadata.Count == 0)
            {
                <div style="color: rgba(0,0,0,0.35); font-size: 0.875rem;">No metadata entries found.</div>
            }
            else
            {
                <Table TItem="CatalogMetadataEntryDto"
                       DataSource="@_catalogInfo.Metadata"
                       Size="@TableSize.Small"
                       PageSize="int.MaxValue"
                       PaginationPosition="none"
                       Bordered>
                    <PropertyColumn Property="e => e.Key" Title="Key">
                        <span style="font-family: monospace;">@context.Key</span>
                    </PropertyColumn>
                    <PropertyColumn Property="e => e.Value" Title="Value">
                        <span style="font-family: monospace; font-size: 0.8rem; word-break: break-all;">@context.Value</span>
                    </PropertyColumn>
                    <PropertyColumn Property="e => e.Scope" Title="Scope" Width="90px">
                        @(context.Scope ?? "—")
                    </PropertyColumn>
                </Table>
            }
        </div>
    </div>
}
else
{
    <div style="padding: 20px; overflow-y: auto; height: 100%;">
        @* Header *@
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px; flex-wrap: wrap;">
            <span style="font-family: monospace; font-size: 1.1rem; font-weight: 600;">
                @Selection.CatalogName<span style="opacity: 0.45;">.</span>@Selection.SchemaName<span style="opacity: 0.45;">.</span>@Selection.ObjectName
            </span>
            @if (Selection.ObjectType == "VIEW")
            {
                <Tag Color="@("purple")">View</Tag>
            }
            else
            {
                <Tag Color="@("blue")">Table</Tag>
            }
        </div>

        @* Comment *@
        @if (!string.IsNullOrWhiteSpace(Selection.Table.Comment))
        {
            <div style="margin-bottom: 20px;">
                <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
                            letter-spacing: 0.05em; opacity: 0.5; margin-bottom: 6px;">Comment</div>
                <div style="font-size: 0.9rem;">@Selection.Table.Comment</div>
            </div>
        }

        @* Columns *@
        <div>
            <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase;
                        letter-spacing: 0.05em; opacity: 0.5; margin-bottom: 6px;">
                Columns (@Selection.Table.Columns.Count)
            </div>

            @if (Selection.Table.Columns.Count == 0)
            {
                <div style="color: rgba(0,0,0,0.35); font-size: 0.875rem;">
                    No column information available.
                </div>
            }
            else
            {
                <Table TItem="ColumnDto"
                       DataSource="@Selection.Table.Columns"
                       Size="@TableSize.Small"
                       PageSize="int.MaxValue"
                       PaginationPosition="none"
                       Bordered>
                    <PropertyColumn Property="c => c.Name" Title="Name">
                        <span style="font-family: monospace;">@context.Name</span>
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.DataType" Title="Type">
                        <span style="font-family: monospace; font-size: 0.8rem;">@context.DataType</span>
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.IsNullable" Title="Nullable" Width="80px">
                        @if (context.IsNullable)
                        {
                            <Icon Type="@IconType.Outline.Check" Style="color: #52c41a;" />
                        }
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.PartitionKeyIndex" Title="Partition" Width="100px">
                        @if (context.PartitionKeyIndex is { } idx)
                        {
                            var label = (idx + 1).ToString();
                            var transform = context.PartitionTransform;
                            var showTransform = !string.IsNullOrEmpty(transform) && transform != "identity";
                            <Tooltip Title="@(showTransform ? $"Partition key #{idx + 1} · transform: {transform}" : $"Partition key #{idx + 1}")">
                                <Tag Style="cursor: default;">
                                    #@label@(showTransform ? $" · {transform}" : "")
                                </Tag>
                            </Tooltip>
                        }
                    </PropertyColumn>
                    <PropertyColumn Property="c => c.Comment" Title="Comment">
                        @(context.Comment ?? "")
                    </PropertyColumn>
                </Table>
            }
        </div>
    </div>
}

@code {
    [Parameter] public CatalogObjectSelection? Selection { get; set; }

    private CatalogInfoDto? _catalogInfo;
    private bool _catalogInfoLoading;
    private string? _catalogInfoError;
    private Guid? _loadedCatalogId;

    protected override async Task OnParametersSetAsync()
    {
        if (Selection?.SelectedCatalog is { } catalog)
        {
            if (catalog.Id == _loadedCatalogId) return;

            _loadedCatalogId = catalog.Id;
            _catalogInfo = null;
            _catalogInfoError = null;
            _catalogInfoLoading = true;
            StateHasChanged();

            try
            {
                _catalogInfo = await CatalogService.GetCatalogInfoAsync(catalog.Id);
            }
            catch (Exception ex)
            {
                _catalogInfoError = $"Failed to load catalog info: {ex.Message}";
            }
            finally
            {
                _catalogInfoLoading = false;
            }
        }
        else
        {
            _loadedCatalogId = null;
            _catalogInfo = null;
            _catalogInfoError = null;
        }
    }
}
