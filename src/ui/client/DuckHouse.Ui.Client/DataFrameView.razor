@using DuckHouse.Core.Kernels

<Table TItem="Dictionary<string, object>"
       DataSource="@_dictRows"
       Size="TableSize.Small"
       Bordered
       HidePagination="true"
       ScrollY="400px"
       Style="max-width: 100%;">
    @foreach (var col in Data.Columns)
    {
        var colName = col.Name;
        <PropertyColumn Title="@colName"
                        Property="@(r => r[colName])"
                        Align="@(IsNumeric(col) ? ColumnAlign.Right : ColumnAlign.Left)">
            <span style="font-family: monospace;">@FormatCell(context[colName])</span>
        </PropertyColumn>
    }
</Table>

@if (FooterLabel is { } label)
{
    <p style="font-size: 0.875rem; margin-bottom: 0; margin-top: 4px;"><Text Type="TextElementType.Secondary">@label</Text></p>
}

@code {
    [Parameter, EditorRequired] public DataFrameOutput Data { get; set; } = default!;

    private List<Dictionary<string, object?>> _dictRows = [];

    protected override void OnParametersSet()
        => _dictRows = Data.Rows
            .Select(row => Data.Columns
                .Select((col, i) => (col.Name, Value: i < row.Count ? row[i] : null))
                .ToDictionary(x => x.Name, x => x.Value))
            .ToList();

    private string? FooterLabel =>
        Data.TotalRows == DataFrameOutput.RowCap
            ? $"{DataFrameOutput.RowCap:N0}+ rows"
            : Data.DisplayedRows < Data.TotalRows
                ? $"Showing {Data.DisplayedRows:N0} of {Data.TotalRows:N0} rows"
                : null;

    private static bool IsNumeric(DataFrameColumn col) =>
        col.Type is "number" or "integer";

    private static string FormatCell(object? value) =>
        value is null ? "" : value.ToString() ?? "";
}
