@using DuckHouse.Core.Kernels

<div class="df-view @(Fill ? "df-view-fill" : "")">
    <table class="df-table">
        <thead>
            <tr>
                @foreach (var col in Data.Columns)
                {
                    <th style="@(IsNumeric(col) ? "text-align: right;" : "")">@col.Name</th>
                }
            </tr>
        </thead>
        <tbody>
            <Virtualize Items="_rows" Context="row" ItemSize="33" SpacerElement="tr">
                <tr>
                    @for (int i = 0; i < Data.Columns.Count; i++)
                    {
                        var col = Data.Columns[i];
                        var cell = i < row.Count ? row[i] : null;
                        <td style="font-family: monospace; @(IsNumeric(col) ? "text-align: right;" : "")">@FormatCell(cell)</td>
                    }
                </tr>
            </Virtualize>
        </tbody>
    </table>
</div>

@if (FooterLabel is { } label)
{
    <p style="font-size: 0.875rem; margin-bottom: 0; margin-top: 4px;">
        @label
    </p>
}

@code {
    [Parameter, EditorRequired] public DataFrameOutput Data { get; set; } = default!;
    [Parameter] public bool Fill { get; set; }

    private List<IReadOnlyList<object?>> _rows = [];
    private DataFrameOutput? _lastData;
    private bool _dataChanged;

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(Data, _lastData)) return;
        _lastData = Data;
        _dataChanged = true;
        _rows = [..Data.Rows];
    }

    protected override bool ShouldRender()
    {
        if (!_dataChanged) return false;
        _dataChanged = false;
        return true;
    }

    private string? FooterLabel =>
        Data.TotalRows == DataFrameOutput.RowCap
            ? $"{DataFrameOutput.RowCap:N0}+ rows"
            : Data.DisplayedRows < Data.TotalRows
                ? $"Showing {Data.DisplayedRows:N0} of {Data.TotalRows:N0} rows"
                : null;

    private static bool IsNumeric(DataFrameColumn col) =>
        col.Type is "number" or "integer";

    private static string FormatCell(object? value) =>
        value is null ? "" : value.ToString() ?? "";
}
