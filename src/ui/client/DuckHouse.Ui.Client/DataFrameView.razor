@using DuckHouse.Core.Kernels

<div class="overflow-auto border rounded" style="max-height: 400px;">
    <table class="table table-sm table-bordered table-striped mb-0">
        <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
            <tr>
                @foreach (var col in Data.Columns)
                {
                    <th class="@(IsNumeric(col) ? "text-end" : "") text-nowrap small fw-semibold">
                        @col.Name
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            <Virtualize Items="_rows" Context="row" ItemSize="33" SpacerElement="tr" OverscanCount="5">
                <tr>
                    @for (int i = 0; i < Data.Columns.Count; i++)
                    {
                        var col = Data.Columns[i];
                        var cell = i < row.Count ? row[i] : null;
                        <td class="@(IsNumeric(col) ? "text-end" : "") text-nowrap font-monospace small">
                            @FormatCell(cell)
                        </td>
                    }
                </tr>
            </Virtualize>
        </tbody>
    </table>
</div>

@if (FooterLabel is { } label)
{
    <p class="text-muted small mb-0 mt-1">@label</p>
}

@code {
    [Parameter, EditorRequired] public DataFrameOutput Data { get; set; } = default!;

    // Virtualize.Items requires ICollection<T>; materialise once when Data changes.
    private List<IReadOnlyList<object?>> _rows = [];

    protected override void OnParametersSet() => _rows = [..Data.Rows];

    private string? FooterLabel =>
        Data.TotalRows == DataFrameOutput.RowCap
            ? $"{DataFrameOutput.RowCap:N0}+ rows"
            : Data.DisplayedRows < Data.TotalRows
                ? $"Showing {Data.DisplayedRows:N0} of {Data.TotalRows:N0} rows"
                : null;

    private static bool IsNumeric(DataFrameColumn col) =>
        col.Type is "number" or "integer";

    private static string FormatCell(object? value) =>
        value is null ? "" : value.ToString() ?? "";
}
