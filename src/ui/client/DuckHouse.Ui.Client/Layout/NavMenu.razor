@inject NavigationManager Navigation
@inject IJobService JobService
@using DuckHouse.Ui.Shared.Orchestration

<Menu Mode="MenuMode.Vertical"
      Theme="MenuTheme.Dark"
      SelectedKeys="@_selectedKeys"
      Style="border-right: none;">
    <div class="logo" />
    <SubMenu Key="new" TitleTemplate="@_newTitle">
        <MenuItem Key="new-notebook" OnClick="@(() => Navigation.NavigateTo("/notebook"))">
            <Icon Type="@IconType.Outline.FileText" />
            <span>Notebook</span>
        </MenuItem>
        <MenuItem Key="new-query" OnClick="@(() => Navigation.NavigateTo("/query"))">
            <Icon Type="@IconType.Outline.Code" />
            <span>SQL query</span>
        </MenuItem>
        <MenuItem Key="new-job" OnClick="StartCreateJob">
            <Icon Type="@IconType.Outline.Partition" />
            <span>Job</span>
        </MenuItem>
    </SubMenu>
    <MenuItem Key="home" OnClick="@(() => Navigation.NavigateTo("/"))">
        <Icon Type="@IconType.Outline.Home" />
        <span>Home</span>
    </MenuItem>
    <MenuItem Key="notebook" OnClick="@(() => Navigation.NavigateTo("/workspace"))">
        <Icon Type="@IconType.Outline.FolderOpen" />
        <span>Workspace</span>
    </MenuItem>
    <MenuItem Key="jobs" OnClick="@(() => Navigation.NavigateTo("/jobs"))">
        <Icon Type="@IconType.Outline.Partition" />
        <span>Jobs</span>
    </MenuItem>
    <MenuItem Key="catalogs" OnClick="@(() => Navigation.NavigateTo("/catalogs"))">
        <Icon Type="@IconType.Outline.Database" />
        <span>Catalogs</span>
    </MenuItem>
    <MenuItem Key="node-pools" OnClick="@(() => Navigation.NavigateTo("/node-pools"))">
        <Icon Type="@IconType.Outline.Cluster" />
        <span>Node pools</span>
    </MenuItem>
    <MenuItem Key="nodes" OnClick="@(() => Navigation.NavigateTo("/nodes"))">
        <Icon Type="@IconType.Outline.CloudServer" />
        <span>Active nodes</span>
    </MenuItem>
    <MenuItem Key="environment" OnClick="@(() => Navigation.NavigateTo("/environment"))">
        <Icon Type="@IconType.Outline.Tool" />
        <span>Environment</span>
    </MenuItem>
    <MenuItem Key="settings" OnClick="@(() => Navigation.NavigateTo("/settings"))">
        <Icon Type="@IconType.Outline.Setting" />
        <span>Settings</span>
    </MenuItem>
</Menu>

<Modal Title="New job"
       Visible="_showCreateJobModal"
       OnOk="ConfirmCreateJobAsync"
       OnCancel="@(() => _showCreateJobModal = false)"
       OkButtonProps="@(new ButtonProps { Disabled = string.IsNullOrWhiteSpace(_newJobName), Loading = _creatingJob })">
    <div style="display: flex; flex-direction: column; gap: 16px;">
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Name</label>
            <Input @bind-Value="_newJobName" Placeholder="My Job" />
        </div>
        <div>
            <label style="display: block; margin-bottom: 4px; font-weight: 500;">Description</label>
            <TextArea @bind-Value="_newJobDescription" Placeholder="Optional description" Rows="3" />
        </div>
        @if (_createJobError is not null)
        {
            <Alert Type="@AlertType.Error" Message="@_createJobError" ShowIcon="true" />
        }
    </div>
</Modal>

<style>
    .logo {
        height: 32px;
        background: rgba(255, 255, 255, 0.2);
        margin: 16px;
    }
</style>

@code {
    private string[] _selectedKeys = [];

    private readonly RenderFragment _newTitle =
        @<span>
            <Icon Type="@IconType.Outline.Plus" />
            <span>New</span>
        </span>;

    // New job modal state
    private bool _showCreateJobModal;
    private string _newJobName = "";
    private string? _newJobDescription;
    private bool _creatingJob;
    private string? _createJobError;

    private void StartCreateJob()
    {
        _newJobName = "";
        _newJobDescription = null;
        _createJobError = null;
        _showCreateJobModal = true;
    }

    private async Task ConfirmCreateJobAsync()
    {
        if (string.IsNullOrWhiteSpace(_newJobName)) return;
        _creatingJob = true;
        _createJobError = null;
        try
        {
            var job = await JobService.CreateJobAsync(
                new CreateJobRequest(_newJobName.Trim(), _newJobDescription?.Trim(), null, 1));
            _showCreateJobModal = false;
            Navigation.NavigateTo($"/jobs/{job.Id}");
        }
        catch (Exception ex)
        {
            _createJobError = $"Failed to create job: {ex.Message}";
        }
        finally
        {
            _creatingJob = false;
        }
    }

    protected override void OnInitialized() => UpdateSelectedKey();

    protected override void OnParametersSet() => UpdateSelectedKey();

    private void UpdateSelectedKey()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.TrimEnd('/');
        _selectedKeys = path switch
        {
            "" or "/" => ["home"],
            _ when path.StartsWith("/nodes") => ["nodes"],
            _ when path.StartsWith("/workspace") => ["notebook"],
            _ when path.StartsWith("/notebook") => ["notebook"],
            _ when path.StartsWith("/query") => ["notebook"],
            _ when path.StartsWith("/jobs") => ["jobs"],
            _ when path.StartsWith("/runs") => ["jobs"],
            _ when path.StartsWith("/node-pools") => ["node-pools"],
            _ when path.StartsWith("/environment") => ["environment"],
            _ when path.StartsWith("/catalogs") => ["catalogs"],
            _ when path.StartsWith("/settings") => ["settings"],
            _ => []
        };
    }
}
